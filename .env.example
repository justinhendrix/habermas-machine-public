# LLM Provider Configuration
# Options: 'anthropic' or 'openai'
LLM_PROVIDER=anthropic

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Model override (optional)
# Anthropic default: claude-haiku-4-5-20251001
# OpenAI default: gpt-4o-mini
# LLM_MODEL=claude-haiku-4-5-20251001

# Instructor admin secret — used to create and manage sessions
# Set this to any random string. Share it only with the instructor.
INSTRUCTOR_SECRET=change-me-to-a-random-string

# Database
# For local dev with SQLite: DATABASE_URL="file:./habermas.db" (change prisma schema provider to "sqlite")
# For production with Postgres:
DATABASE_URL="postgresql://user:password@host:5432/habermas"
